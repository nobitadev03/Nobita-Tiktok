# ============================================================
# 🤖 NOBITA BOT - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your actual values

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=7xxx:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin User ID (your Telegram user ID)
ADMIN_USER_ID=123456789

# Dashboard Security Token (set a strong password)
DASHBOARD_TOKEN=your_secure_random_password_here

# Maximum concurrent download requests
MAX_CONCURRENT_REQUESTS=3

# Node Environment (production or development)
NODE_ENV=production

# Server Port (Render sets this automatically, usually 3000)
PORT=3000

# ============================================================
# Optional: For local testing
# ============================================================
# BOT_URL=http://localhost:3000
# RENDER_EXTERNAL_URL=your_render_url_here

# ============================================================
# Instructions:
# 1. Rename this file to .env
# 2. Replace xxx values with your actual credentials
# 3. For ADMIN_USER_ID: Send /start to your bot, it will show your ID
# 4. For DASHBOARD_TOKEN: Create a strong random string
# 5. Never commit .env file to git!
# ============================================================
